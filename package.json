    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "minimatch": "^10.0.0",
    "glob": "^10.0.0",
    "tmp": "^0.2.3",
