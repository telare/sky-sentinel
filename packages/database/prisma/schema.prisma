generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FailureType {
  HARDWARE
  SOFTWARE // Помилки цілісності даних (XOR)
  NETWORK // Проблеми зі зв'язком (RSSI/Latency)
  AERODYNAMIC // Звалювання (Stall)
  FLIGHT_DYNAMICS // Жорсткі посадки (Hard Landing)
  OTHER
}

enum Severity {
  CRITICAL
  WARNING
  INFO
}

model FailureLog {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp   DateTime    @default(now())
  type        FailureType
  severity    Severity
  description String?
  isResolved  Boolean     @default(false)

  uavData   UAVdata @relation(fields: [uavDataId], references: [id])
  uavDataId String  @db.Uuid
}

model UAVdata {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp DateTime @default(now())

  // Геодезичні дані
  latitude  Float
  longitude Float
  altitude  Float

  // Динаміка польоту (необхідно для діагностики)
  verticalSpeed Float // Для детекції Hard Landing
  airspeed      Float // Для детекції Stall
  pitch         Float
  roll          Float

  // Стан систем
  gear_status   Int
  battery_level Float
  temperature   Float // Для детекції Overheat

  // Мережеві параметри (для діагностики NETWORK)
  rssi    Float? // Рівень сигналу (dBm)
  latency Float? // Затримка (ms)

  // Added for Analytical Redundancy (Lecture №10)
  groundSpeed  Float // From GPS (to compare with Airspeed)
  throttle     Float // 0-100% (to compare with RPM/Vertical Speed)
  servoCurrent Float // To detect servo stalls/blockage

  // Emergency State (Section 5 of lectures)
  logs          FailureLog[]

  @@index([timestamp])
}
